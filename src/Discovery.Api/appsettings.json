{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=discovery;Username=postgres;Password="
  },
  "Nats": {
    "AuthCallout": {
      "Enabled": true
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Reporting": {
    "EnablePdf": true
  },
  "OpenTelemetry": {
    "Enabled": false,
    "ServiceName": "discovery-api",
    "Protocol": "grpc",
    "OtlpEndpoint": "",
    "Headers": "",
    "MetricExportIntervalMilliseconds": 10000,
    "EnableHttpClientInstrumentation": true,
    "EnableRuntimeInstrumentation": true
  },
  "AutoTicket": {
    "Enabled": false,
    "ShadowMode": true,
    "ReopenWindowMinutes": 0,
    "MaxCreatedTicketsPerHourPerAlertCode": 0,
    "CanaryClientIds": [],
    "CanarySiteIds": []
  },
  "BackgroundJobs": {
    "KnowledgeEmbeddingEnabled": false,
    "KnowledgeEmbeddingQueueEnabled": true
  },
  "Security": {
    "Cors": {
      "AllowedOrigins": [
        "https://app.example.com"
      ]
    }
  },
  "AllowedHosts": "*",
  "AgentPackage": {
    "Profiles": {
      "linux": {
        "DiscoveryProjectPath": "/opt/discovery-agent-src",
        "BinaryPath": "/opt/discovery-agent-src/src/build/bin/discovery-agent.exe",
        "OutputName": "discovery-agent.exe"
      },
      "windows": {
        "DiscoveryProjectPath": "C:\\Discovery",
        "BinaryPath": "C:\\Discovery\\src\\build\\bin\\discovery-agent.exe",
        "OutputName": "discovery-agent.exe"
      }
    },
    "PublicApiScheme": "https",
    "PublicApiServer": "api.example.com"
  },
  "MeshCentral": {
    "Enabled": false,
    "BaseUrl": "https://mesh.example.com/",
    "IgnoreTlsErrors": false,
    "EnableProvisioningHints": true,
    "IdentitySyncMeshMembershipRights": 0,
    "IdentitySyncDeviceAclRevocationEnabled": false
  },
  "Authentication": {
    "Jwt": {
      "PrivateKeyPath": "keys/jwt-private.pem",
      "PublicKeyPath": "keys/jwt-public.pem",
      "Issuer": "discovery",
      "Audience": "discovery"
    },
    "Fido2": {
      "ServerDomain": "app.example.com",
      "Origins": [
        "https://app.example.com"
      ]
    }
  }
}
