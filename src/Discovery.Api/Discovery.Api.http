@Discovery.Api_HostAddress = http://localhost:5288

# Variáveis de IDs existentes (atualize conforme seu ambiente)
@clientId = 019cc52c-fa75-7692-b973-6568edbdf168
@siteId = 019cc533-2967-72d9-8702-e545dd6ca794
@agentId = 019cc554-3703-7519-bd64-de415f110d31
@ticketId = 019cc56d-decf-7579-860b-e0c84004e7d6

###
# Clients

GET {{Discovery.Api_HostAddress}}/api/clients
Accept: application/json

###
# Agents - List by Client

GET {{Discovery.Api_HostAddress}}/api/agents/by-client/{{clientId}}
Accept: application/json

###
# Agents - Get by ID

GET {{Discovery.Api_HostAddress}}/api/agents/{{agentId}}
Accept: application/json

###
# Workflow States - List All

GET {{Discovery.Api_HostAddress}}/api/workflow/states
Accept: application/json

###
# ===== TICKETS =====

# Tickets - List All

GET {{Discovery.Api_HostAddress}}/api/tickets
Accept: application/json

###
# Tickets - List by Client

GET {{Discovery.Api_HostAddress}}/api/tickets/by-client/{{clientId}}
Accept: application/json

###
# Tickets - Get by ID

GET {{Discovery.Api_HostAddress}}/api/tickets/{{ticketId}}
Accept: application/json

###
# Tickets - Create

POST {{Discovery.Api_HostAddress}}/api/tickets
Content-Type: application/json

{
  "clientId": "{{clientId}}",
  "siteId": "{{siteId}}",
  "agentId": "{{agentId}}",
  "title": "Problema de Conectividade",
  "description": "O agente está apresentando problemas de conexão intermitente com o servidor",
  "priority": "High",
  "category": "Network"
}

###
# Tickets - Create (com Department e Profile)

POST {{Discovery.Api_HostAddress}}/api/tickets
Content-Type: application/json

{
  "clientId": "{{clientId}}",
  "siteId": "{{siteId}}",
  "agentId": "{{agentId}}",
  "departmentId": null,
  "workflowProfileId": null,
  "title": "Atualização de Software Necessária",
  "description": "O agente necessita de atualização urgente do antivírus",
  "priority": "Medium",
  "category": "Software",
  "assignedToUserId": null
}

###
# Tickets - Update

PUT {{Discovery.Api_HostAddress}}/api/tickets/{{ticketId}}
Content-Type: application/json

{
  "title": "Problema de Conectividade - ATUALIZADO",
  "description": "O agente está apresentando problemas de conexão intermitente. Já tentamos reiniciar o serviço.",
  "priority": "Critical",
  "category": "Network",
  "assignedToUserId": null
}

###
# Tickets - Update Workflow State (transição de estados)

PATCH {{Discovery.Api_HostAddress}}/api/tickets/{{ticketId}}/workflow-state
Content-Type: application/json

{
  "workflowStateId": "019cbbe6-ddf1-7ef9-a715-b879c2dea3f2"
}

###
# Tickets - Get Comments

GET {{Discovery.Api_HostAddress}}/api/tickets/{{ticketId}}/comments
Accept: application/json

###

POST {{Discovery.Api_HostAddress}}/api/tickets/{{ticketId}}/comments
Content-Type: application/json

{
  "author": "Técnico Suporte",
  "content": "Iniciando investigação do problema de conectividade",
  "isInternal": false
}

###
# Tickets - Update

PUT {{Discovery.Api_HostAddress}}/api/tickets/{{ticketId}}
Content-Type: application/json

{
  "title": "Problema de Conectividade - ATUALIZADO",
  "description": "O agente está apresentando problemas de conexão intermitente. Já tentamos reiniciar o serviço.",
  "priority": "Critical",
  "category": "Network",
  "assignedToUserId": null
}

###
