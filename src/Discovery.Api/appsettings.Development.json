{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=discovery_dev;Username=postgres;Password="
  },
  "HostOptions": {
    "BackgroundServiceExceptionBehavior": "Ignore"
  },
  "OpenTelemetry": {
    "Enabled": false,
    "Protocol": "grpc",
    "MetricExportIntervalMilliseconds": 10000
  },
  "AutoTicket": {
    "Enabled": false,
    "ShadowMode": true,
    "ReopenWindowMinutes": 0,
    "MaxCreatedTicketsPerHourPerAlertCode": 0,
    "CanaryClientIds": [],
    "CanarySiteIds": []
  },
  "Security": {
    "Cors": {
      "AllowWildcardInDevelopment": true
    },
    "RateLimiting": {
      "General": {
        "PermitLimit": 300
      },
      "Auth": {
        "PermitLimit": 30
      },
      "Agent": {
        "PermitLimit": 900
      }
    }
  },
  "AgentPackage": {
    "PublicApiScheme": "http",
    "PublicApiServer": "localhost:5288"
  },
  "Authentication": {
    "Fido2": {
      "ServerDomain": "localhost",
      "Origins": [
        "http://localhost:5173",
        "https://localhost:5173",
        "http://localhost:5288",
        "https://localhost:5288",
        "http://localhost:5001",
        "https://localhost:5001"
      ]
    }
  }
}
