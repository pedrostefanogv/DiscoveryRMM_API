# Copie para discovery-install.env e ajuste os valores.
# Uso:
#   chmod 600 discovery-install.env
#   ./scripts/linux/install_discovery_server.sh --config ./discovery-install.env --non-interactive

# Repositorios
DISCOVERY_GIT_REPO="https://github.com/pedrostefanogv/DiscoveryRMM_API"
DISCOVERY_AGENT_GIT_REPO="https://github.com/pedrostefanogv/DiscoveryRMM_Agent"
DISCOVERY_SITE_GIT_REPO="https://github.com/pedrostefanogv/DiscoveryRMM_Site"
DISCOVERY_GIT_BRANCH="release"
# Canal sugerido: lts | release | beta | dev
# Se DISCOVERY_GIT_BRANCH estiver vazio no modo interativo, o instalador pergunta o canal.
# DISCOVERY_RELEASE_CHANNEL opcional para compatibilidade (mesmo valor de branch).
DISCOVERY_RELEASE_CHANNEL=""

# Token GitHub (bootstrap). Use apenas se o repositorio for privado.
# Use token temporario e rotacione apos instalar.
GITHUB_PAT=""

# Bootstrap quando o script for executado como root.
# Em modo interativo, o instalador pede estes valores automaticamente.
# Em modo --non-interactive como root, preencha ambos.
DISCOVERY_INSTALL_USER="discovery"
DISCOVERY_INSTALL_USER_PASSWORD=""

# Acesso: internal | external | hybrid
ACCESS_MODE="internal"
INTERNAL_API_HOST="api.interno.local"
EXTERNAL_API_HOST=""
CLOUDFLARE_TUNNEL_TOKEN=""

# OpenAPI/Scalar
# 1 = habilitado, 0 = desativado
OPENAPI_ENABLED="0"

# Banco
POSTGRES_DB="discovery"
POSTGRES_USER="discovery_app"
POSTGRES_PASSWORD="troque-esta-senha"

# NATS
NATS_USER="discovery_nats"
NATS_PASSWORD="troque-esta-senha"
NATS_AUTH_USER="auth"
NATS_AUTH_PASSWORD="troque-esta-senha-forte"
NATS_BIND_HOST="0.0.0.0"
NATS_MONITOR_HOST="127.0.0.1"
NATS_AUTH_CALLOUT_ENABLED="1"
NATS_AUTH_CALLOUT_SUBJECT="\$SYS.REQ.USER.AUTH"
NATS_AUTH_CALLOUT_ISSUER="Axxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Caminhos
DISCOVERY_API_BASE="/opt/discovery-api"
DISCOVERY_SITE_BASE="/opt/discovery-site"
DISCOVERY_AGENT_SRC="/opt/discovery-agent-src"
DISCOVERY_AGENT_ARTIFACTS="/opt/discovery-agent-artifacts"
DISCOVERY_OPS_DIR="/opt/discovery-ops"

# Portal web
# Vazio = mesma origem do Nginx (recomendado)
DISCOVERY_SITE_API_URL=""
# Opcoes: signalr | nats | both
# Padrao recomendado do instalador: signalr
DISCOVERY_SITE_REALTIME_PROVIDER="signalr"
DISCOVERY_SITE_NATS_ENABLED="false"
# Use ws:// ou wss:// apenas se expuser NATS/WebSocket para o browser.
DISCOVERY_SITE_NATS_URL=""

# Dotnet publish
DISCOVERY_DOTNET_RUNTIME="linux-x64"
